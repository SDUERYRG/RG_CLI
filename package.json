{
  "name": "rg_cli",
  "version": "0.1.0",
  "description": "A terminal UI CLI built with Bun, Ink, and React.",
  "type": "module",
  "private": true,
  "main": "./dist/cli.cjs",
  "exports": {
    ".": "./dist/cli.cjs"
  },
  "bin": {
    "rg-cli": "./dist/cli.cjs"
  },
  "files": [
    "dist/cli.cjs",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "@types/react": "^19.2.14",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "ink": "^6.8.0",
    "ink-text-input": "6.0.0",
    "react": "^19.2.4"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bun build ./src/index.ts --target=node --format=cjs --packages=external --external react-devtools-core --outfile ./dist/cli.cjs",
    "start": "node ./dist/cli.cjs",
    "pack:cli": "npm pack",
    "prepack": "bun run build"
  }
}
